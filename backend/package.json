{
  "name": "gig-kavacham-backend",
  "version": "1.0.0",
  "description": "GigKavacham Node.js Backend Proxy",
  "main": "src/app.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start-ml": "py -3.10 ml/services/ml_server.py",
    "train-all": "py -3.10 ml/scripts/train_all_models.py",
    "check-ml": "curl http://localhost:5001/health"
  },
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
